route async POST api $record {
	if (!%CSRF->verify) return apply(error: 'Invalid CSRF token')
	if (!$this->model = CMS::uriRecordFind($record)) return false
	if (!$this->model::canCreate()) return apply(error: 'Not allowed')
	$this->record = phlo($this->model, ...array_intersect_key(%payload->objData, array_filter($this->fields, fn($f) => $this->writable($f))))
	$this->applySave && location(slash.($this->model::$uriRecord ?? $this->model).slash.$this->record->id)
}

route async POST api $record $id $fieldName {
	if (!%CSRF->verify) return apply(error: 'Invalid CSRF token')
	if (!($parent = CMS::uriRecordFind($record)) || !($field = $parent::fields()[$fieldName] ?? null) || $field->type !== 'child') return false
	$this->model = $field->obj
	if (!$this->model::canCreate()) return apply(error: 'Not allowed')
	$this->record = phlo($this->model, ...array_intersect_key(%payload->objData, array_filter($this->fields, fn($f) => $this->writable($f))), ...[($field->key ?? $parent) => $id])
	$this->applySave && location(slash.$record.slash.$id.slash.$fieldName.slash.$this->record->id)
}

route async PUT api $record $id {
	if (!%CSRF->verify) return apply(error: 'Invalid CSRF token')
	if (!$this->model = CMS::uriRecordFind($record)) return false
	$this->id = $id
	$this->record = $this->model::record(id: $id)
	if (!$this->model::canChange($this->record)) return apply(error: 'Not allowed')
	$this->applySave && location(slash.($this->model::$uriRecord ?? $this->model).slash.$id)
}

route async PUT api $record $id $fieldName $childId {
	if (!%CSRF->verify) return apply(error: 'Invalid CSRF token')
	if (!($parent = CMS::uriRecordFind($record)) || !($field = $parent::fields()[$fieldName] ?? null) || $field->type !== 'child') return false
	$this->model = $field->obj
	$this->id = $childId
	$this->record = $this->model::record(id: $childId)
	if (!$this->record || (string)$this->record->{$field->key ?? $parent} !== (string)$id) return false
	if (!$this->model::canChange($this->record)) return apply(error: 'Not allowed')
	$this->applySave && location(slash.$record.slash.$id.slash.$fieldName.slash.$childId)
}

route async PATCH api $model $id $fieldName {
	if (!%CSRF->verify) return apply(error: 'Invalid CSRF token')
	if (!in_array($model, %app->models) || !($field = $model::fields()[$fieldName] ?? null)) return false
	$this->model = $model
	$this->record = $model::record(id: $id)
	if (!$model::canChange($this->record)) return apply(error: 'Not allowed')
	$old = clone $this->record
	$this->parsePayload($this->fieldsPatch($fieldName))
	$this->event('beforeChange', $old)
	$this->event('beforeSave', $old)
	$this->record->objSave
	$this->event('afterChange', $old)
	$this->event('afterSave', $old)
	$referer = (string)($_SERVER['HTTP_REFERER'] ?? void)
	$expectedPrefix = 'https://'.%req->host.'/'
	location(str_starts_with($referer, $expectedPrefix) ? substr($referer, strlen('https://'.%req->host)) : (slash.$model.slash.$id))
}

route async DELETE api $record $id {
	if (!%CSRF->verify) return apply(error: 'Invalid CSRF token')
	if (!$model = CMS::uriRecordFind($record)) return false
	$this->model = $model
	$this->record = $model::record(id: $id)
	if (!$model::canDelete($this->record)) return apply(error: 'Not allowed')
	$this->event('beforeDelete')
	$model::delete('id=?', $id)
	$this->event('afterDelete')
	location(slash.($model::$uriList ?? $model::$table))
}

route async DELETE api $record $id $fieldName $childId {
	if (!%CSRF->verify) return apply(error: 'Invalid CSRF token')
	if (!($parent = CMS::uriRecordFind($record)) || !($field = $parent::fields()[$fieldName] ?? null) || $field->type !== 'child') return false
	$this->model = $field->obj
	$this->record = $this->model::record(id: $childId)
	if (!$this->record || (string)$this->record->{$field->key ?? $parent} !== (string)$id) return false
	if (!$this->model::canDelete($this->record)) return apply(error: 'Not allowed')
	$this->event('beforeDelete')
	$field->obj::delete('id=?', $childId)
	$this->event('afterDelete')
	location(slash.($parent::$uriRecord ?? $parent).slash.$id)
}

method event($event, ...$args) => method_exists($this->model, $event) && $this->record->$event(...$args)
method fields => array_filter($this->model::fields(), fn($field) => !in_array($field->type, ['child', 'many', 'virtual']))
prop fieldsRequired => array_filter($this->fields, fn($field) => $field->required)
prop fieldsPatch($name) => array_filter($this->fields, fn($field) => $field->handle || $field->name === $name)

method checkRequired {
	$required = []
	foreach ($this->fieldsRequired AS $column => $field){
		$value = %payload->$column ?? $this->record->$column
		if ($value === null || $value === '') $required[] = $field
	}
	return $required ?: true
}

method parsePayload($fields) => loop($fields, [$this, 'parsePayloadField'])
method parsePayloadField($field, $column){
	if (!$this->writable($field)) return
	if ($field->has('parse')) $field->parse($this->record)
	elseif (%payload->hasData($column)) $this->record->$column = %payload->$column
}
method writable($field) => (%req->method === 'POST' ? $field->create : $field->change) !== false
method fieldsMany => array_filter($this->model::fields(), fn($field) => $field->type === 'many' && $this->writable($field))
method syncMany => loop($this->fieldsMany, fn($field) => $field->sync($this->model, $this->record->id))

method applySave {
	if (is_array($required = $this->checkRequired)){
		apply(class: [loop($required, fn($field) => "[name=\"$field->name\"]", ', ') => 'error'], error: 'Fill in all required fields')
		return false
	}
	$old = clone $this->record
	$this->parsePayload($this->fields)
	foreach ($this->model::fields() AS $column => $field){
		if ($field->type === 'many' && $this->record->hasData($column)) unset($this->record->$column)
	}
	$this->event('beforeSave', $old)
	if (%req->method === 'POST'){
		$this->event('beforeCreate')
		$this->record = $this->model::create(...$this->record)
		$this->event('afterCreate')
	}
	if (%req->method === 'PUT'){
		$this->event('beforeChange', $old)
		$this->model::change('id=?', $this->id, ...$this->record) && $this->record = $this->model::record(id: $this->id)
		$this->event('afterChange', $old)
	}
	$this->syncMany
	$this->event('afterSave', $old)
	return true
}
