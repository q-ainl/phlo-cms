<style>
::-webkit-scrollbar {
	background: $bg
	width: 12px
	height: 20px
	\-thumb: background: $primary
}
a: color: $primary
h1, h2 {
	font-size: 1.2em
	font-weight: normal
	margin: 0
}
input.field, select, textarea {
	background: transparent
	border: 0
	font: inherit
	color: $text
	\.error: outline: 1px solid $warn
}
section .body input.field, section .body select, section .body textarea, input.field.full, select.full, textarea.full: width: 100%
input::placeholder {
	color: $text
	opacity: .66
}
select option {
	background: black
	color: white
}
form.create, form.change, section.record .body {
	display: flex
	flex-direction: column
	gap: .9rem
	max-width: 34rem
	padding: 1rem 0 2rem
}
.field {
	display: flex
	flex-direction: column
	gap: .3rem
}
.field > label {
	color: $muted
	font-size: .8rem
}
.field > .input, .field > .label {
	background: $surface
	border: 1px solid $border
	border-radius: 8px
	padding: .5rem .65rem
}
.field > .label {
	color: $text
	min-height: 1.15em
}
.field > .input:focus-within: border-color: $primary
.field > .input input.field, .field > .input select, .field > .input textarea {
	width: 100%
}
.ms-grid {
	display: flex
	flex-wrap: wrap
	gap: .4rem .9rem
	padding: .25rem 0
}
.ms-opt {
	align-items: center
	cursor: pointer
	display: inline-flex
	gap: .35rem
}
.ms-opt input {
	width: auto
	margin: 0
}
button, .btn {
	background: $surface
	border-radius: 6px
	color: $text
	cursor: pointer
	display: inline-block
	border: 0
	font: inherit
	font-size: .9em
	outline: 0
	text-align: center
	text-decoration: none
	\.primary: background: $primary
	\.warning: background: $warn
}
section header {
	background: $bg
	display: flex
	flex-wrap: wrap
	gap: .5rem
	justify-content: end
	line-height: 30px
	margin: 1.25em 0 0
	padding: 0 .5rem
	position: sticky
	left: 0
	z-index: 1
	h1, h2: flex: auto
	.count {
		background: $warn
		border-radius: 100%
		display: inline-block
		font-size: .8em
		font-weight: bold
		text-align: center
		min-width: 2em
	}
	button, .btn {
		height: 2em
		margin-top: 5px
	}
}
#more {
	display: block
	margin: auto
}
dialog {
	animation: 200ms dialog
	background: $bg
	border: 1px solid $primary
	border-radius: 6px
	color: $text
	\::backdrop {
		backdrop-filter: blur(12px)
		background-color: #ABC2
		cursor: pointer
	}
	button: border: 1px solid $primary
}
@keyframes dialog: from: transform: scale(.5)
</style>
