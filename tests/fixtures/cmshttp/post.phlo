@ class:   post
@ extends: model

static table = 'posts'

static schema => arr(
	id: field(type: 'number', title: 'ID'),
	title: field(type: 'text', title: 'Title'),
	body: field(type: 'text', title: 'Body'),
)

static prepareTable {
	static::DB()->query('DROP TABLE IF EXISTS posts')
	static::DB()->query('CREATE TABLE posts (id INTEGER PRIMARY KEY AUTOINCREMENT, title TEXT, body TEXT)')
}
