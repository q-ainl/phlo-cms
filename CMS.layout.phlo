static __handle => null

#controller:
if (%req->async) return
%app->css = []
%app->theme && %app->css[] = '/theme.'.%app->theme.'.css'
%app->trans && %app->css[] = '/trans.'.%app->trans.'.css'

route async GET set theme $name= {
	$clean = $name ? preg_replace('/[^a-z0-9-]/', void, strtolower($name)) : void
	%session->theme = ($clean && is_file(www.'theme.'.$clean.'.css')) ? $clean : null
	return apply(...array_filter(arr(
		remove: 'link[href^="/theme."]',
		css: %session->theme ? '/theme.'.%session->theme.'.css' : null,
		class: ['.cms-theme' => '-is-active', '.cms-theme[data-name="'.(%session->theme ?? void).'"]' => 'is-active'],
		trans: %app->trans ?? true,
	)))
}

route async GET set trans $name= {
	$clean = $name ? preg_replace('/[^a-z0-9-]/', void, strtolower($name)) : void
	%session->trans = ($clean && is_file(www.'trans.'.$clean.'.css')) ? $clean : null
	return apply(...array_filter(arr(
		remove: 'link[href^="/trans."]',
		css: %session->trans ? '/trans.'.%session->trans.'.css' : null,
		class: ['.cms-trans' => '-is-active', '.cms-trans[data-name="'.(%session->trans ?? void).'"]' => 'is-active'],
		trans: %session->trans ?: true,
	)))
}

method assetName($file) => substr(basename($file, '.css'), 6)

view => $this->top.$this->nav.lf.$this->toggle

view nav:
<nav>
	<a href="/"{{ active(%app->active === 'dashboard', 'async') }}><i>⚡</i>Dashboard</a>
	<foreach %app->menu AS $model => $item>
		<a href="/$item[uri]"{{ active(%app->active === $model, 'async') }}><i>$item[icon]</i>$item[title]</a>
		<if %app->active === $model && class_exists($model) && method_exists($model, 'objFilters')>
			<foreach $model::objFilters() AS $key => $f>
				<a.sub.async href="/$item[uri]/f=$key"><i>·</i>{{ esc($f['title']) }}</a>
			</foreach>
		</if>
		<if %app->active === $model && class_exists($model) && method_exists($model, 'subNav')>
			<foreach $model::subNav() AS $sub>
				<a href="$sub[uri]"{{ active($sub['active'], 'sub async'.(($sub['cls'] ?? null) ? space.$sub['cls'] : void)) }}><i>{( $sub['icon'] ?? '·' )}</i>{{ esc($sub['title']) }}</a>
			</foreach>
		</if>
	</foreach>
	{{ $this->tools }}
</nav>

view toggle: <div#menuToggle title=Toggle+menu/>

view tools:
<div.cms-tools>
	<div.cms-tool>
		<button.cms-tool-toggle type=button title=Thema aria-label=Thema><svg viewBox="0 0 24 24" width=18 height=18 fill=none stroke=currentColor stroke-width=2><circle cx=12 cy=12 r=9/><path d="M12 3a9 9 0 0 1 0 18z" fill=currentColor stroke=none/></svg></button>
		<div.cms-pop.cms-pop-list>
			<a href="/set/theme" data-name="" class="async cms-theme{( %app->theme ? void : ' is-active' )}">Standaard</a>
			<foreach files(www, 'theme.*.css') AS $file>
			<a href="/set/theme/{{ $this->assetName($file) }}" data-name="{{ $this->assetName($file) }}" class="async cms-theme{( %app->theme === $this->assetName($file) ? ' is-active' : void )}">{{ ucfirst($this->assetName($file)) }}</a>
			</foreach>
		</div>
	</div>
	<div.cms-tool>
		<button.cms-tool-toggle type=button title=Animatie aria-label=Animatie><svg viewBox="0 0 24 24" width=18 height=18 fill=none stroke=currentColor stroke-width=2 stroke-linecap=round stroke-linejoin=round><path d="M3 8h14l-4-4"/><path d="M21 16H7l4 4"/></svg></button>
		<div.cms-pop.cms-pop-list>
			<a href="/set/trans" data-name="" class="async cms-trans{( %app->trans ? void : ' is-active' )}">Standaard</a>
			<foreach files(www, 'trans.*.css') AS $file>
			<a href="/set/trans/{{ $this->assetName($file) }}" data-name="{{ $this->assetName($file) }}" class="async cms-trans{( %app->trans === $this->assetName($file) ? ' is-active' : void )}">{{ ucfirst($this->assetName($file)) }}</a>
			</foreach>
		</div>
	</div>
</div>

<script>
on('click', '.cms-tool-toggle', (btn) => {
	const tool = btn.closest('.cms-tool')
	const open = !tool.classList.contains('open')
	objects('.cms-tool.open').forEach(t => t.classList.remove('open'))
	if (open){
		tool.classList.add('open')
		const pop = tool.querySelector('.cms-pop')
		const r = btn.getBoundingClientRect()
		pop.style.left = Math.min(r.right + 8, innerWidth - pop.offsetWidth - 8) + 'px'
		pop.style.bottom = (innerHeight - r.bottom) + 'px'
	}
	return false
})
on('click', '.cms-pop a', (a) => a.closest('.cms-tool').classList.remove('open'))
on('click', '#menuToggle', (toggle) => apply(() => toggle.classList.toggle('hide'), true))
</script>

<style>
body:has(> nav) {
	background: $bg
	color: $text
	display: flex
	gap: 0 .5em
	height: 100dvh
	margin: 0
	overflow-x: hidden
	@media(max-width:800px): flex-direction: column-reverse
}
@media(min-width:801px){
	#menuToggle {
		background: $primary
		border-radius: 5px
		cursor: pointer
		border: 1px solid $surface
		margin-top: 50vh
		width: 10px
		height: 44px
	}
	body:has(#menuToggle.hide) nav {
		width: 32px
		\:hover: overflow: visible
		a {
			width: 32px
			\:hover {
				width: fit-content
				z-index: 2
			}
		}
	}
}
nav {
	display: flex
	flex-direction: column
	gap: .5rem .25rem
	height: 100dvh
	overflow-x: hidden
	overflow-y: auto
	padding: 1rem 0
	a {
		border-top-right-radius: 16px
		border-bottom-right-radius: 16px
		color: $text
		display: block
		flex-shrink: 0
		overflow: hidden
		padding: .5rem
		text-decoration: none
		white-space: nowrap
		i: font-style: normal
		\:hover, \.active: background: $primary
		\:last-child: margin-top: auto
		\.sub {
			font-size: .82em
			opacity: .7
			padding-top: .3rem
			padding-bottom: .3rem
		}
		\.sub.active: opacity: 1
		i {
			display: inline-block
			font-size: .85em
			margin-left: -6px
			text-align: center
			width: 30px
		}
	}
	@media(max-width:800px){
		flex-direction: row
		font-size: .85em
		height: initial
		justify-content: space-around
		overflow: hidden
		padding: .5rem 0
		a {
			border-radius: 16px
			display: none
			padding: .25rem .5rem
			\:nth-child(-n+4), \:last-child: display: block
		}
	}
	@media(max-width:520px): a {
		overflow: hidden
		padding: .25rem
		width: 26px
		\.active: width: auto
		\:not(.active) i: margin-right: .5rem
		i: width: 20px
	}
}
main {
  flex: 1
	padding: 0 .5rem
  overflow: auto
	section: display: contents
}
.cms-tools {
	margin-top: auto
	display: flex
	flex-direction: row
	gap: .25rem
	padding: .25rem .5rem
}
.cms-tool: position: relative
.cms-tool-toggle {
	background: transparent
	border: 0
	color: $text
	cursor: pointer
	font-size: 1.1rem
	line-height: 1
	padding: .4rem
	text-align: left
	width: 100%
}
.cms-tool-toggle i: font-style: normal
.cms-tool-toggle:hover: background: $primary
.cms-pop {
	background: $surface
	border: 1px solid $border
	border-radius: 8px
	box-shadow: 0 8px 24px rgba(0,0,0,.4)
	display: none
	flex-wrap: wrap
	gap: .35rem
	max-width: 248px
	padding: .5rem
	position: fixed
	width: max-content
	z-index: 50
}
.cms-tool.open .cms-pop: display: flex
.cms-pop-list {
	flex-direction: column
	flex-wrap: nowrap
	max-height: 60vh
	overflow-y: auto
}
.cms-pop-list a {
	border-radius: 6px
	color: $text
	padding: .25rem .5rem
	text-decoration: none
	white-space: nowrap
}
.cms-pop-list a:hover, .cms-pop-list a.is-active: background: $primary
@media(max-width:800px){
	.cms-tools {
		flex-direction: row
		margin-top: 0
	}
}
</style>
